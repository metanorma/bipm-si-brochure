</math></stem>
</td>
<td valign="top" align="left">
<stem type="MathML"><math xmlns="http://www.w3.org/1998/Math/MathML"><mn>1.3</mn><mo>&#215;</mo><msup><mrow><mn>10</mn></mrow><mrow><mrow><mi>&#8722;</mi><mn>9</mn></mrow></mrow></msup></math></stem>
</td>
