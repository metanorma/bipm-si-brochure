<stem type="MathML"><math xmlns="http://www.w3.org/1998/Math/MathML"><mstyle mathvariant="normal"><mrow><msup><mrow><mn>5</mn></mrow><mrow><mn>3</mn></mrow></msup><msub><mrow><mi>P</mi></mrow><mrow><mn>0</mn></mrow></msub><mo>&#8722;</mo><msup><mrow><mn>6</mn></mrow><mrow><mn>3</mn></mrow></msup><msub><mrow><mi>S</mi></mrow><mrow><mn>1</mn></mrow></msub></mrow></mstyle></math></stem>
</td>
