<stem type="MathML"><math xmlns="http://www.w3.org/1998/Math/MathML"><msub><mrow><mi>u</mi></mrow><mrow><mi>c</mi></mrow></msub><mo>/</mo><mi>y</mi><mo>=</mo><mn>1.3</mn><mo>&#215;</mo><msup><mrow><mn>10</mn></mrow><mrow><mrow><mo>&#8722;</mo><mn>9</mn></mrow></mrow></msup></math></stem></p>
<p id="_a391c724-eb1b-462d-93e4-f166e25d8511">for which:<br/>
<stem type="MathML"><math xmlns="http://www.w3.org/1998/Math/MathML"><mstyle mathvariant="italic"><mi>&#955;</mi></mstyle><mo>=</mo><mn>605&#8239;780&#8239;210.3</mn><mtext>&#160;</mtext><mfenced open="(" close=")"><mrow><mi>.</mi><mn>8</mn></mrow></mfenced><mo rspace="thickmathspace">&#8290;</mo><mrow xref="U_fm"><mi mathvariant="normal">fm</mi></mrow>








</math></stem><br/>
<stem type="MathML"><math xmlns="http://www.w3.org/1998/Math/MathML"><msub><mrow><mi>u</mi></mrow><mrow><mi>c</mi></mrow></msub><mo>/</mo><mi>y</mi><mo>=</mo><mn>1.3</mn><mo>&#215;</mo><msup><mrow><mn>10</mn></mrow><mrow><mrow><mo>&#8722;</mo><mn>9</mn></mrow></mrow></msup></math></stem></p>
</dd>
