<td id="_f18079d9-6c64-8e7f-bba6-7aeefa71b169" valign="top" align="left"><stem block="false" type="MathML"><math xmlns="http://www.w3.org/1998/Math/MathML"><mstyle displaystyle="false"><mn>20.7</mn></mstyle></math><asciimath>20.7</asciimath></stem></td>
