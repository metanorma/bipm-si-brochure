<table id="_6273bdc8-91af-64d1-8d3b-eb175d9e4b41" unnumbered="true"><thead><tr id="_2c94c1cf-b8ff-ab3d-6318-d7a898a08287"><th id="_d3232890-53df-37ab-278e-644c2d96ef26" valign="top" align="left"><stem block="false" type="MathML"><math xmlns="http://www.w3.org/1998/Math/MathML">
  <mstyle displaystyle="false">
    <mi>f</mi>
    <mo>/</mo>
