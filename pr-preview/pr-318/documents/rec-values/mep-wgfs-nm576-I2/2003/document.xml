<dl id="_15ae814d-f9e7-7f1b-7c5e-5f98f964cefc"><dt>The values</dt>
<dd id="_e37ba030-c875-69ec-9a9d-37d78c7505e2"><p id="_d0092b22-7c88-063c-a707-161b74fddf89"><stem block="false" type="MathML"><math xmlns="http://www.w3.org/1998/Math/MathML">
