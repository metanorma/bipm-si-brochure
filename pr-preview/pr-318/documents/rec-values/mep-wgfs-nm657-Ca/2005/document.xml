    <mn>455986240494140</mn>
    <mo rspace="thickmathspace">⁢</mo>
    <mrow xref="U_NISTu31">
      <mstyle mathvariant="normal">
        <mi>Hz</mi>
      </mstyle>
      
      
      
      
    </mrow>
  </mstyle>
</math><asciimath>f = 455986240494140 "unitsml(Hz)"</asciimath></stem><br/>
<stem block="false" type="MathML"><math xmlns="http://www.w3.org/1998/Math/MathML">
  <mstyle displaystyle="false">
    <mstyle mathvariant="italic">
      <mi>λ</mi>
    </mstyle>
    <mo>=</mo>
    <mn>657459439.291683</mn>
    <mo rspace="thickmathspace">⁢</mo>
    <mrow xref="U_fm">
      <mstyle mathvariant="normal">
        <mi>fm</mi>
