</math><asciimath>1.0 "unitsml(mm)"</asciimath></stem> Hg (<stem block="false" type="MathML"><math xmlns="http://www.w3.org/1998/Math/MathML">
  <mstyle displaystyle="false">
    <mn>66</mn>
    <mo rspace="thickmathspace">⁢</mo>
    <mrow xref="U_NISTu12">
      <mstyle mathvariant="normal">
        <mi>Pa</mi>
      </mstyle>
      
      
    </mrow>
  </mstyle>
</math><asciimath>66 "unitsml(Pa)"</asciimath></stem> to <stem block="false" type="MathML"><math xmlns="http://www.w3.org/1998/Math/MathML">
  <mstyle displaystyle="false">
    <mn>133</mn>
    <mo rspace="thickmathspace">⁢</mo>
    <mrow xref="U_NISTu12">
