    <mo>×</mo>
    <msup>
      <mn>10</mn>
      <mrow>
        <mi>−</mi>
        <mn>8</mn>
      </mrow>
    </msup>
  </mstyle>
</math><asciimath>ii(U) = 2 xx 10^(−8)</asciimath></stem>, where <stem block="false" type="MathML"><math xmlns="http://www.w3.org/1998/Math/MathML">
  <mstyle displaystyle="false">
    <mstyle mathvariant="italic">
