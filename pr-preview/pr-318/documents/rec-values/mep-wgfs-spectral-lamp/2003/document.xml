</math><asciimath>ii(U) = 5 xx 10^(−8)</asciimath></stem>, where <stem block="false" type="MathML"><math xmlns="http://www.w3.org/1998/Math/MathML">
  <mstyle displaystyle="false">
    <mstyle mathvariant="italic">
      <mi>U</mi>
    </mstyle>
