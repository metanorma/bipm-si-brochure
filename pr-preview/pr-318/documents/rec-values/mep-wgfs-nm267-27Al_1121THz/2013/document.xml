<clause id="_f2d72ff6-a3b1-4bed-cc7d-e6dad677df10" obligation="normative">
<title id="_28c0e7c9-1acf-a669-d5cb-efc436d20d01">Recommended value <eref type="inline" bibitemid="ci2013" citeas="[1]"/> of the frequency</title>
<p id="_3f91963a-e90f-385a-7c23-6033e9dc26d5"><stem block="false" type="MathML"><math xmlns="http://www.w3.org/1998/Math/MathML">
  <mstyle displaystyle="false">
    <mi>f</mi>
    <mrow>
      <mo>(</mo>
      <msup>
        <mtext/>
        <mn>27</mn>
      </msup>
      <msup>
        <mstyle mathvariant="normal">
          <mrow>
            <mi>A</mi>
            <mi>l</mi>
          </mrow>
        </mstyle>
        <mtext>+</mtext>
      </msup>
      <mo>)</mo>
    </mrow>
    <mo>=</mo>
    <mn>1121015393207857.3</mn>
    <mo rspace="thickmathspace">⁢</mo>
    <mrow xref="U_NISTu31">
      <mstyle mathvariant="normal">
        <mi>Hz</mi>
      </mstyle>
      
      
      
      
    </mrow>
  </mstyle>
</math><asciimath>f (""^27 rm(Al)^"+") = 1121015393207857.3 "unitsml(Hz)"</asciimath></stem></p>

<p id="_a467da43-663b-a604-4bf2-fe0f7987d2d0">equivalent to</p>

<p id="_62176488-a0e4-94f5-e452-ea0279f6dece"><stem block="false" type="MathML"><math xmlns="http://www.w3.org/1998/Math/MathML">
  <mstyle displaystyle="false">
    <mstyle mathvariant="italic">
      <mi>λ</mi>
    </mstyle>
    <mrow>
      <mo>(</mo>
      <msup>
        <mtext/>
        <mn>27</mn>
      </msup>
      <msup>
        <mstyle mathvariant="normal">
          <mrow>
            <mi>A</mi>
            <mi>l</mi>
          </mrow>
        </mstyle>
        <mo>+</mo>
      </msup>
      <mo>)</mo>
    </mrow>
    <mo>=</mo>
    <mn>267429385.730489</mn>
    <mo rspace="thickmathspace">⁢</mo>
    <mrow xref="U_fm">
      <mstyle mathvariant="normal">
        <mi>fm</mi>
      </mstyle>
      
      
      
    </mrow>
  </mstyle>
</math><asciimath>ii(lambda) (""^27 rm(Al)^{+}) = 267429385.730489 "unitsml(fm)"</asciimath></stem>,</p>

<p id="_2c8ff573-adf9-693d-a116-78716d97df4f">with an estimated relative standard uncertainty of <stem block="false" type="MathML"><math xmlns="http://www.w3.org/1998/Math/MathML">
  <mstyle displaystyle="false">
    <mn>1.9</mn>
    <mo>×</mo>
    <msup>
      <mn>10</mn>
      <mrow>
        <mo>−</mo>
        <mn>15</mn>
      </mrow>
    </msup>
  </mstyle>
</math><asciimath>1.9 xx 10^(-15)</asciimath></stem>.</p>

<p id="_4ce54abf-6c8b-39c1-42c5-486c1e22fe88">This radiation was endorsed as a secondary representation of the definition of the second.</p>
</clause>

